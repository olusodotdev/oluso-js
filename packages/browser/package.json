{
    "name": "@oluso/browser",
    "version": "1.0.0",
    "description": "Shared browser client for Oluso error monitoring, used by @oluso/react and @oluso/vue",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "scripts": {
