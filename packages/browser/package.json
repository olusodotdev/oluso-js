    },
    "bugs": {
        "url": "https://github.com/olusodotdev/oluso-js/issues"
    },
    "homepage": "https://github.com/olusodotdev/oluso-js/tree/main/packages/browser#readme",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "dependencies": {
        "@oluso/core": "1.0.0",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^18.15.11",
        "jest": "^29.5.0",
        "jest-environment-jsdom": "^29.5.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.4"
