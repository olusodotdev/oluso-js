{
    "name": "@oluso/nextjs",
    "version": "1.0.0",
    "description": "Oluso error monitoring for Next.js applications: instrumentation hooks, route/middleware wrappers, and React bindings for the App Router and Pages Router",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./client": {
            "types": "./dist/client.d.ts",
            "default": "./dist/client.js"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsc",
        "test": "jest"
    },
    "keywords": [
        "error",
        "monitoring",
        "reporting",
        "nextjs",
        "next",
        "react",
        "app-router",
        "edge",
        "error-tracking",
        "error-monitoring",
        "ai",
        "crash-reporting",
        "logging",
        "debugging"
    ],
    "author": "David Ezeh",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/olusodotdev/oluso-js.git",
        "directory": "packages/nextjs"
    },
    "bugs": {
        "url": "https://github.com/olusodotdev/oluso-js/issues"
    },
    "homepage": "https://github.com/olusodotdev/oluso-js/tree/main/packages/nextjs#readme",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "dependencies": {
        "@oluso/core": "1.0.0",
        "@oluso/react": "1.1.0",
        "tslib": "^2.8.1"
    },
    "peerDependencies": {
        "next": ">=13.4.0",
        "react": ">=18.2.0"
    },
    "devDependencies": {
        "@testing-library/react": "^16.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^18.15.11",
        "@types/react": "^18.2.0",
        "jest": "^29.5.0",
        "jest-environment-jsdom": "^29.5.0",
        "next": "^14.2.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.4"
    }
}
