{
    "name": "@oluso/angular",
    "version": "1.0.0",
    "description": "Oluso error monitoring for Angular applications: an ErrorHandler, DI providers, and an injectOluso() helper for automatic and manual error reporting",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsc",
        "test": "jest"
    },
    "keywords": [
        "error",
        "monitoring",
        "reporting",
        "angular",
        "error-handler",
        "error-tracking",
        "error-monitoring",
        "ai",
        "crash-reporting",
        "logging",
        "debugging"
    ],
    "author": "David Ezeh",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/olusodotdev/oluso-js.git",
        "directory": "packages/angular"
    },
    "bugs": {
        "url": "https://github.com/olusodotdev/oluso-js/issues"
    },
    "homepage": "https://github.com/olusodotdev/oluso-js/tree/main/packages/angular#readme",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "dependencies": {
        "@oluso/browser": "1.0.0",
        "tslib": "^2.8.1"
    },
    "peerDependencies": {
        "@angular/core": ">=15.0.0",
        "rxjs": ">=7.0.0"
    },
    "devDependencies": {
        "@angular/compiler": "^20.0.0",
        "@angular/compiler-cli": "^20.0.0",
        "@angular/core": "^20.0.0",
        "@types/jest": "^30.0.0",
        "jest": "^29.5.0",
        "jest-preset-angular": "^14.1.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.0",
        "ts-jest": "^29.1.0",
        "typescript": "^5.0.4",
        "zone.js": "~0.15.0"
    }
}
